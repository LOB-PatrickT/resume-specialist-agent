{
  "metadata": {"framework": "Role Ambiguity Structuring", "version": "1.0", "description": "Show breadth without dilution by grouping duties into competency lanes."},
  "lanes": [
    {"name": "Financial Oversight", "examples": ["Managed budgets of $X", "Tracked variance ±Y%", "Supported forecasting"]},
    {"name": "Vendor & Stakeholder", "examples": ["Negotiated with X vendors", "Managed SLAs", "Coordinated cross-team deliverables"]},
    {"name": "Technical Documentation", "examples": ["Authored specs", "Maintained SOPs", "Defined acceptance criteria"]}
  ],
  "template": "\u25B6 [Lane]: [metric/result] — [evidence]",
  "rules": [
    "3–5 bullets max",
    "Lead with the most business-relevant lane",
    "Avoid mixing lanes in one bullet"
  ]
}

